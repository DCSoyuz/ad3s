    <!--
        Factory build profile.

        The default (public) build compiles src/main/java + src/registers/java,
        where the register enums (Regs / RegField / AllRegAddr) are stripped of
        factory registers and FactoryGate is an inert stub. The public artifact
        therefore contains no factory register definitions at all.

        Activating -Pfactory overrides ${registers.src} to src/factory/java, so the
        build-helper compiles the full register enums + the real FactoryGate instead.
        Build with:
            mvn -Pfactory package
        src/factory is git-ignored and never published.
    -->
    <profiles>
        <profile>
            <id>factory</id>
            <properties>
                <registers.src>src/factory/java</registers.src>
            </properties>
        </profile>
    </profiles>



